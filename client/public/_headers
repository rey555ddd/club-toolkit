# 🔒 資安 headers（2026-04-26 朋友 audit P2 #6 — 套用到中國城酒店 club 工具站）
# Cloudflare Pages 會在每個回應自動套用這份 _headers

/*
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), magnetometer=(), gyroscope=(), accelerometer=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: https: blob:; connect-src 'self' https://generativelanguage.googleapis.com https://forge.manus.im https://ai.dev https://api.anthropic.com https://api.openai.com https://*.fal.run https://queue.fal.run; frame-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'
